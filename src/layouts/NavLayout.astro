---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>{pageTitle}</title>
    </head>
    <body>
      <nav class="top-nav">
          <a href="/" class="shrink-0 flex items-center">
            <Image src={logo} alt="Matt Cotter" class="h-6 w-auto" />
          </a>

          <div class="flex items-center gap-4 text-sm">
              {navLinks.slice(1).map((link) => (
                <a href={link.href}>{link.name}</a>
              ))}
          </div>

          <div class="divider hidden sm:block"></div>

          <div class="hidden sm:flex items-center gap-3">
              {socialLinks.map((link) => (
                <a href={link.href} target="_blank" rel="noopener noreferrer" aria-label={link.name}>
                  <span set:html={link.svg}></span>
                </a>
              ))}
          </div>
      </nav>

      <main class="container">
        <slot />
      </main>

      <footer class="site-footer">
        <div class="flex items-center gap-4">
            {socialLinks.map((link) => (
              <a href={link.href} target="_blank" rel="noopener noreferrer" aria-label={link.name}>
                <span set:html={link.svg}></span>
              </a>
            ))}
        </div>
        <a href="mailto:cotter.m@gmail.com" class="meta block mt-3">cotter.m@gmail.com</a>
        <p class="meta mt-1">© {new Date().getFullYear()} Matt Cotter</p>
      </footer>
    </body>
</html>
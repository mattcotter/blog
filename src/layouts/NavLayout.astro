---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>{pageTitle}</title>
        <!-- Google tag (gtag.js) -->
        <script async src="https://www.googletagmanager.com/gtag/js?id=G-VB1TSGDEV4"></script>
        <script is:inline>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());

          gtag('config', 'G-VB1TSGDEV4');
        </script>

        <script is:inline>
          (function () {
            const stored = localStorage.getItem('theme');
            const theme = stored || (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
            document.documentElement.setAttribute('data-theme', theme);
          })();
        </script>
    </head>
    <body>
      <div class="top-bar"></div>

      <nav class="top-nav">
          <a href="/" class="shrink-0 flex items-center">
            <Image src={logo} alt="Matt Cotter" class="h-6 w-auto" />
          </a>

          <div class="flex items-center gap-4 text-sm">
              {navLinks.slice(1).map((link) => (
                <a href={link.href}>{link.name}</a>
              ))}
          </div>

          <div class="divider hidden sm:block"></div>

          <div class="hidden sm:flex items-center gap-3">
              {socialLinks.map((link) => (
                <a href={link.href} target="_blank" rel="noopener noreferrer" aria-label={link.name}>
                  <span set:html={link.svg}></span>
                </a>
              ))}
          </div>
      </nav>

      <button id="theme-toggle" class="theme-toggle-btn" aria-label="Toggle color theme">
        <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1.5m0 15V21m8.485-8.485h-1.5m-13.97 0h-1.5m14.849-6.364-1.06 1.06M6.196 17.804l-1.06 1.06m12.728 0-1.06-1.06M6.196 6.196l-1.06-1.06M16.5 12a4.5 4.5 0 1 1-9 0 4.5 4.5 0 0 1 9 0Z" />
        </svg>
        <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" />
        </svg>
      </button>

      <main class="container">
        <slot />
      </main>

      <footer class="site-footer">
        <div class="flex justify-between items-start gap-8">
          <div>
            <div class="flex items-center gap-4">
              {socialLinks.map((link) => (
                <a href={link.href} target="_blank" rel="noopener noreferrer" aria-label={link.name}>
                  <span set:html={link.svg}></span>
                </a>
              ))}
            </div>
      
            <a href="mailto:cotter.m@gmail.com" class="meta block mt-3">
              cotter.m@gmail.com
            </a>
      
            <p class="meta mt-1">
              © {new Date().getFullYear()} Matt Cotter
            </p>
          </div>
      
          <div class="text-right">
            <a href="#" id="game-trigger" class="meta">
              🕹️ Let's Play a Game...
            </a>
          </div>
        </div>
      </footer>

      <div id="game-overlay" class="game-overlay" hidden>
        <div class="game-modal-box">
          <button id="game-close" class="game-close" aria-label="Close">&times;</button>
          <h3>Let's Play a Game</h3>
          <p id="game-message">Guess a number between 1 and 5.</p>
          <div class="game-input-row">
            <input id="game-guess" type="number" min="1" max="5" inputmode="numeric" />
            <button id="game-submit">Guess</button>
          </div>
        </div>
      </div>

      <script is:inline>
        const themeToggle = document.getElementById('theme-toggle');
        themeToggle.addEventListener('click', () => {
          const current = document.documentElement.getAttribute('data-theme');
          const next = current === 'light' ? 'dark' : 'light';
          document.documentElement.setAttribute('data-theme', next);
          localStorage.setItem('theme', next);
        });

        const gameTrigger = document.getElementById('game-trigger');
        const gameOverlay = document.getElementById('game-overlay');
        const gameClose = document.getElementById('game-close');
        const gameSubmit = document.getElementById('game-submit');
        const gameGuess = document.getElementById('game-guess');
        const gameMessage = document.getElementById('game-message');
        let target = Math.floor(Math.random() * 5) + 1;
        let hasAlerted = false;

        function openGame() {
          target = Math.floor(Math.random() * 5) + 1;
          hasAlerted = false;
          gameMessage.textContent = 'Guess a number between 1 and 5.';
          gameGuess.value = '';
          gameOverlay.hidden = false;
          gameGuess.focus();
        }

        function closeGame() {
          gameOverlay.hidden = true;
        }

        function submitGuess() {
          const guess = parseInt(gameGuess.value, 10);
          if (!guess || guess < 1 || guess > 5) {
            gameMessage.textContent = 'Enter a number between 1 and 5.';
            return;
          }
          if (guess === target) {
            document.documentElement.classList.remove('comic-sans-mode');
            gameMessage.textContent = "🎉 You got it!";
            setTimeout(closeGame, 1200);
          } else {
            document.documentElement.classList.add('comic-sans-mode');
            gameMessage.textContent = 'Guess again to change it back.';
            if (!hasAlerted) {
              hasAlerted = true;
              alert('OH NO, you changed everything to comic sans! Guess again to change it back.');
            }
          }
        }

        gameTrigger.addEventListener('click', (e) => {
          e.preventDefault();
          openGame();
        });
        gameClose.addEventListener('click', closeGame);
        gameOverlay.addEventListener('click', (e) => {
          if (e.target === gameOverlay) closeGame();
        });
        gameSubmit.addEventListener('click', submitGuess);
        gameGuess.addEventListener('keydown', (e) => {
          if (e.key === 'Enter') submitGuess();
        });
      </script>
    </body>
</html>
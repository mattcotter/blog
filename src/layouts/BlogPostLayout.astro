---
import NavLayout from './NavLayout.astro';
const { frontmatter } = Astro.props;
---

<NavLayout pageTitle={frontmatter.title}>
  <article class="pt-6 prose prose-invert max-w-none">
    <h1>{frontmatter.title}</h1>
    <p class="meta">
      By {frontmatter.author} · <time datetime={frontmatter.pubDate}>{new Date(frontmatter.pubDate).toLocaleDateString()}</time>
    </p>
    <hr />
    <slot />

    {frontmatter.tags && frontmatter.tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mt-8 pt-6">
        {frontmatter.tags.map((tag: string) => (
          <a href={`/tags/${tag}`} class="tag">{tag}</a>
        ))}
      </div>
    )}
  </article>
</NavLayout>
---
import NavLayout from '../layouts/NavLayout.astro';

import fs from 'fs';
import path from 'path';
import matter from 'gray-matter';

const pageTitle = "Matt Cotter | Blog";
const blogDir = './src/pages/blog';
const files = fs.readdirSync(blogDir).filter(file => file.endsWith('.md'));

type PostMeta = {
  title: string;
  pubDate: string;
  tags?: string[];
  url: string;
};

const posts: PostMeta[] = files.map(file => {
  const filePath = path.join(blogDir, file);
  const content = fs.readFileSync(filePath, 'utf-8');
  const { data } = matter(content);

  return {
    title: data.title,
    pubDate: data.pubDate,
    tags: data.tags ?? [],
    url: `/blog/${file.replace('.md', '')}`,
  };
});

posts.sort((a, b) => {
  const dateA = new Date(a.pubDate).getTime() || 0;
  const dateB = new Date(b.pubDate).getTime() || 0;
  return dateB - dateA;
});
---

<NavLayout pageTitle={pageTitle}>
  <section class="pt-6">
    <h1 class="mb-6">Blog</h1>
    <ul class="space-y-6">
      {posts.map((post) => (
        <li class="pb-6 border-b border-[var(--border)] last:border-0">
          <span class="meta block mb-1">{new Date(post.pubDate).toLocaleDateString()}</span>
          <a href={post.url} class="text-lg font-medium">{post.title}</a>
          {post.tags && post.tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-2">
              {post.tags.map(tag => (
                <a href={`/tags/${tag}`} class="tag">{tag}</a>
              ))}
            </div>
          )}
        </li>
      ))}
    </ul>
  </section>
</NavLayout>

---
import NavLayout from '../layouts/NavLayout.astro';
import { Image } from 'astro:assets';
import matt1 from '../assets/matt-1.png';

const pageTitle = "Matt Cotter | About";

const jobs = [
  {
    company: "Connor Group",
    role: "Lead Web Developer",
    dates: "September 2025 – Present",
    stack: "WordPress, Divi, ACF, WP-CLI, Yardi CRM integrations",
  },
  {
    company: "Reborn Consultants",
    role: "Lead Web Developer",
    dates: "July 2024 – September 2025",
    stack: "WordPress, Elementor, Beaver Builder, ACF, Figma",
  },
  {
    company: "Self-employed",
    role: "Freelance Web Developer",
    dates: "November 2023 – Present",
    stack: "WordPress, Shopify, PHP",
  },
  {
    company: "Stratacache",
    role: "Application Developer",
    dates: "October 2021 – January 2024",
    stack: "Vue, TypeScript",
  },
  {
    company: "NASIC, Department of Defense",
    role: "IT Specialist — Wright-Patterson Air Force Base",
    dates: "September 2020 – October 2021",
    stack: "Vue, Django, Nuxt.js, Agile, TS Clearance",
  },
  {
    company: "GE Aerospace",
    role: "Lead Front End Developer",
    dates: "October 2018 – April 2020",
    stack: "Vue, JavaScript, CI/CD, API, Agile",
  },
  {
    company: "RCF Information Systems",
    role: "Web Developer",
    dates: "June 2018 – October 2018",
    stack: "Agile, contract work at Wright-Patterson AFB",
  },
  {
    company: "Think Patented",
    role: "Full Stack Developer",
    dates: "January 2017 – June 2018",
    stack: "Rebrand of TDH Marketing as Bitstorm Connect",
  },
  {
    company: "TDH Marketing",
    role: "Web Developer",
    dates: "December 2014 – January 2017",
    stack: "Joomla, Drupal, WordPress, SEO",
  },
];
---

<NavLayout pageTitle={pageTitle}>
  <section class="pt-6 flex flex-col sm:flex-row gap-6 items-start">
    <Image src={matt1} alt="Matt Cotter" class="w-24 h-24 rounded-full object-cover shrink-0" />
    <div>
      <h1>Hey, I'm Matt</h1>
      <p>I'm a front-end developer with over 12 years of experience.</p>
      <p>
        I've worked with companies large and small, building robust, user-focused
        solutions across a range of industries — from internal tooling for the
        Department of Defense to marketing sites for small businesses.
      </p>
      <p>
        I've helped build McDonald's digital menu boards and led front-end efforts
        for GE Aerospace's internal design system, used by hundreds of engineers
        worldwide. No matter the size of the project, I focus on dependable work
        that bridges design and development.
      </p>
    </div>
  </section>

  <hr />

  <section>
    <h2 class="mb-4">Experience</h2>
    <ul class="space-y-6">
      {jobs.map((job) => (
        <li class="card">
          <div class="flex items-baseline justify-between flex-wrap gap-1">
            <h3 class="!mb-0">{job.company}</h3>
            <span class="meta">{job.dates}</span>
          </div>
          <p class="mt-1 mb-1 italic">{job.role}</p>
          <span class="meta">{job.stack}</span>
        </li>
      ))}
    </ul>
  </section>
</NavLayout>
---
import NavLayout from '../layouts/NavLayout.astro';

interface BlogPostFrontmatter {
  pubDate: string;
  title: string;
  description?: string;
}

const pageTitle = "Matt Cotter";

const allPosts = Object.values(import.meta.glob('./blog/*.md', { eager: true }));

const sortedPosts = allPosts.sort((a, b) => {
  const dateA = new Date((a as any).frontmatter.pubDate);
  const dateB = new Date((b as any).frontmatter.pubDate);
  return dateB.getTime() - dateA.getTime();
});

const latestPosts = sortedPosts.slice(0, 3) as any[];
---

<NavLayout pageTitle={pageTitle}>
  <section class="pt-6">
    <h1>Matt Cotter</h1>
    <p>
      Front-end developer with 13+ years of experience, based in Cincinnati, Ohio.
      I build clean, dependable interfaces, from internal tools to marketing sites.
    </p>
    <p>
      <a href="/about">More about me →</a>
    </p>
  </section>

  <section class="pt-8">
    <h2 class="mb-2">Testimonial</h2>
    <blockquote>
      "I've worked with Matt for nearly 2 years building my website. He's honest,
      communicative, and knows how to bring a vision to life."
      <footer class="meta mt-2">— Amy Sanford Hammond, Amy Denae Weight Loss</footer>
    </blockquote>
  </section>

  <section class="pt-14">
    <div class="flex items-baseline justify-between mb-2">
      <h2>Latest posts</h2>
      <a href="/blog" class="meta">View all →</a>
    </div>
    <ul class="space-y-4">
      {latestPosts.map(post => (
        <li>
          <a href={post.url} class="block">
            <span class="block text-base font-medium">{post.frontmatter.title}</span>
          </a>
          <span class="meta">{new Date(post.frontmatter.pubDate).toLocaleDateString()}</span>
          {post.frontmatter.description && (
            <p class="mt-1 text-sm">{post.frontmatter.description}</p>
          )}
        </li>
      ))}
    </ul>
  </section>
</NavLayout>
